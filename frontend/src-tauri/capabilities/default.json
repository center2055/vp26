{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:app:allow-set-app-theme",
    "autostart:default",
    "notification:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:17826/*" },
        { "url": "http://127.0.0.1:17827/*" },
        { "url": "http://127.0.0.1:17828/*" },
        { "url": "http://127.0.0.1:17829/*" },
        { "url": "http://127.0.0.1:17830/*" }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/vp26-backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
